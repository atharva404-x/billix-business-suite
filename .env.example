# ==============================================================================
# Billix SaaS Platform — Environment Configuration Template
# Copy this file to '.env' for local development or production configuration.
# NEVER commit the active '.env' or secret-containing files to Git repository.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application Base Settings
# ------------------------------------------------------------------------------
PROJECT_NAME="Billix"
ENV="development"                  # Options: development, staging, production
PORT=8000

# ------------------------------------------------------------------------------
# Logging & Observability
# ------------------------------------------------------------------------------
LOG_LEVEL="INFO"                   # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT="json"                  # Options: json, text
SENTRY_DSN=""                      # Optional: Production Sentry DSN URI
SENTRY_TRACES_SAMPLE_RATE="0.1"


# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------------------------
# For local SQLite dev/testing: sqlite+aiosqlite:///:memory:
# For production PostgreSQL: postgresql+asyncpg://<user>:<password>@<host>:5432/<db_name>
DATABASE_URL="postgresql+asyncpg://billix_user:billix_password@localhost:5432/billix_db"

POSTGRES_DB="billix_db"
POSTGRES_USER="billix_user"
POSTGRES_PASSWORD="change_me_in_production_password"
POSTGRES_HOST="postgres"
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# Cache & Message Broker (Redis)
# ------------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379/0"

# ------------------------------------------------------------------------------
# Clerk Authentication Configuration
# ------------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key_here"
CLERK_SECRET_KEY="sk_test_your_clerk_secret_key_here"
CLERK_JWKS_URL="https://api.clerk.com/v1/.well-known/jwks.json"
CLERK_API_URL="https://api.clerk.com/v1"
CLERK_JWT_AUDIENCE=""             # Optional: set in production to enforce audience validation

# ------------------------------------------------------------------------------
# Frontend Environment Variables (Vite / React)
# ------------------------------------------------------------------------------
VITE_API_BASE_URL="http://localhost:8000"
VITE_CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key_here"
